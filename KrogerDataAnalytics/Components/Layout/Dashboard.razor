@page "/dashboard"
@using KrogerDataAnalytics.Components.Models
@using KrogerDataAnalytics.Service
@inject DataService DataService
@rendermode InteractiveServer

<div class="container-fluid p-4" style="background-color: #f8f9fa;">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold" style="color: #4a148c;">Retail Engagement Dashboard</h2>
        <span class="badge bg-primary p-2">Data Source: Azure SQL for displaying & CSV files for training data</span>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card shadow-sm border-0 border-start border-4 border-primary">
                <div class="card-body">
                    <h6 class="text-muted text-uppercase small fw-bold">Total Households</h6>
                    @if (isLoading)
                    {
                        <div class="spinner-border spinner-border-sm text-primary"></div>
                    }
                    else
                    {
                        <h3 class="mb-0">@householdCount.ToString("N0")</h3>
                    }
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card shadow-sm border-0 border-start border-4 border-success">
                <div class="card-body">
                    <h6 class="text-muted text-uppercase small fw-bold">Latest Transactions</h6>
                    @if (isLoading)
                    {
                        <div class="spinner-border spinner-border-sm text-success"></div>
                    }
                    else
                    {
                        <h3 class="mb-0">@transactionCount.ToString("N0")</h3>
                    }
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card shadow-sm border-0 border-start border-4 border-warning">
                <div class="card-body">
                    <h6 class="text-muted text-uppercase small fw-bold">Total Products</h6>
                    @if (isLoading)
                    {
                        <div class="spinner-border spinner-border-sm text-warning"></div>
                    }
                    else
                    {
                        <h3 class="mb-0">@productCount.ToString("N0")</h3>
                    }
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card shadow-sm border-0 border-start border-4 border-info">
                <div class="card-body">
                    <h6 class="text-muted text-uppercase small fw-bold">Avg Spend/Basket</h6>
                    @if (isLoading)
                    {
                        <div class="spinner-border spinner-border-sm text-info"></div>
                    }
                    else
                    {
                        <h3 class="mb-0">$@avgSpend.ToString("F2")</h3>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-6">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-white fw-bold">Income vs. Engagement (Total Spend)</div>
                <div class="card-body d-flex align-items-center justify-content-center text-center">
                    <div>
                        <i class="bi bi-bar-chart-line display-4 text-secondary"></i>
                        <p class="mt-2 text-muted">Analyzing @householdCount households...</p>
                    </div>
                </div>
                <div class="card-footer small text-muted">Relationship between income levels and total retail spend.</div>
            </div>
        </div>

        <div class="col-lg-6">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-white fw-bold">Spending Trends (2018 - 2020)</div>
                <div class="card-body d-flex align-items-center justify-content-center text-center">
                    <div>
                        <i class="bi bi-graph-up display-4 text-secondary"></i>
                        <p class="mt-2 text-muted">Tracking @transactionCount historical data points...</p>
                    </div>
                </div>
                <div class="card-footer small text-muted">Monthly spend trends over the study period.</div>
            </div>
        </div>

        <div class="row g-4 mt-2">
            <div class="col-lg-6">
                <div class="card shadow-sm h-500">
                    <div class="card-header bg-white fw-bold">Feature Relationships: Brand Type</div>
                    <div class="card-body d-flex align-items-center justify-content-center">
                        <img src="charts/chart_feature_influence_to_brand.png" alt="Feature vs Brand Type" class="img-fluid rounded shadow" style="max-height:400px;" />
                    </div>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="card shadow-sm h-500">
                    <div class="card-header bg-white fw-bold">Feature Relationships: Organic Flag</div>
                    <div class="card-body d-flex align-items-center justify-content-center">
                        <img src="charts/chart_feature_influence_organic.png" alt="Feature vs Organic Flag" class="img-fluid rounded shadow" style="max-height:400px;" />
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="row g-4 mb-4">
        <div class="col-lg-4">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-primary text-white fw-bold d-flex justify-content-between align-items-center">
                    <span>Latest 10 Households</span>
                    <i class="bi bi-people"></i>
                </div>
                <div class="card-body p-0 overflow-auto" style="max-height: 300px;">
                    <table class="table table-sm table-hover mb-0" style="font-size: 0.75rem;">
                        <thead class="table-light sticky-top">
                            <tr>
                                <th>HSHD_NUM</th>
                                <th>Loyalty?</th>
                                <th>Age</th>
                                <th>Income</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (_allHouseholds != null)
                            {
                                @foreach (var hh in _allHouseholds.Take(10))
                                {
                                    <tr>
                                        <td class="fw-bold">@hh.Hshd_num</td>
                                        <td>@hh.Loyalty_flag</td>
                                        <td>@hh.Age_range</td>
                                        <td>@hh.Income_range</td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-success text-white fw-bold d-flex justify-content-between align-items-center">
                    <span>Latest 10 Transactions</span>
                    <i class="bi bi-cart-check"></i>
                </div>
                <div class="card-body p-0 overflow-auto" style="max-height: 300px;">
                    <table class="table table-sm table-hover mb-0" style="font-size: 0.75rem;">
                        <thead class="table-light sticky-top">
                            <tr>
                                <th>Basket</th>
                                <th>Date</th>
                                <th>Spend</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (_allTransactions != null)
                            {
                                @foreach (var trans in _allTransactions.Take(10))
                                {
                                    <tr>
                                        <td>@trans.Basket_num</td>
                                        <td>@trans.Date.ToString()</td>
                                        <td class="text-success fw-bold">$@trans.Spend?.ToString("F2")</td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-warning text-dark fw-bold d-flex justify-content-between align-items-center">
                    <span>Latest 10 Products</span>
                    <i class="bi bi-box-seam"></i>
                </div>
                <div class="card-body p-0 overflow-auto" style="max-height: 300px;">
                    <table class="table table-sm table-hover mb-0" style="font-size: 0.75rem;">
                        <thead class="table-light sticky-top">
                            <tr>
                                <th>ID</th>
                                <th>Department</th>
                                <th>Commodity</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (_allProducts != null)
                            {
                                @foreach (var prod in _allProducts.Take(10))
                                {
                                    <tr>
                                        <td>@prod.Product_num</td>
                                        <td>@prod.Department</td>
                                        <td>@prod.Commodity</td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
@code {
    private List<Household>? _allHouseholds;
    private List<Transaction>? _allTransactions;
    private List<Product>? _allProducts;

    private int householdCount = 0;
    private int transactionCount = 0;
    private int productCount = 0;
    private double avgSpend = 0;
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            isLoading = true;

            // Pulling data from your DataService
            _allHouseholds = await DataService.GetAllHouseholdsAsync();
            _allProducts = await DataService.GetAllProductsAsync();
            _allTransactions = await DataService.GetAllTransactionsAsync();

            // Set counts for KPIs
            householdCount = _allHouseholds?.Count ?? 0;
            productCount = _allProducts?.Count ?? 0;
            transactionCount = _allTransactions?.Count ?? 0;

            if (transactionCount > 0)
            {
                avgSpend = _allTransactions!.Average(t => t.Spend ?? 0);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading dashboard data: {ex.Message}");
        }
        finally
        {
            isLoading = false;
            // This ensures the UI updates once the async calls are finished
            await InvokeAsync(StateHasChanged);
        }
    }
}