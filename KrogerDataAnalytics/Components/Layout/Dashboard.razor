@page "/dashboard"
@using KrogerDataAnalytics.Components.Controllers
@using KrogerDataAnalytics.Service
@using static System.Net.WebRequestMethods
@inject DataService DataService

<div class="container-fluid p-4" style="background-color: #f8f9fa;">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold" style="color: #4a148c;">Retail Engagement Dashboard</h2>
        <span class="badge bg-primary p-2">Data Source: Azure SQL</span>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card shadow-sm border-0 border-start border-4 border-primary">
                <div class="card-body">
                    <h6 class="text-muted text-uppercase small fw-bold">Total Households</h6>
                    <h3 class="mb-0">400</h3>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card shadow-sm border-0 border-start border-4 border-success">
                <div class="card-body">
                    <h6 class="text-muted text-uppercase small fw-bold">Avg Spend/Basket</h6>
                    <h3 class="mb-0">$@avgSpend.ToString("F2")</h3>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card shadow-sm border-0 border-start border-4 border-warning">
                <div class="card-body">
                    <h6 class="text-muted text-uppercase small fw-bold">Organic Share</h6>
                    <h3 class="mb-0">12.5%</h3>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card shadow-sm border-0 border-start border-4 border-info">
                <div class="card-body">
                    <h6 class="text-muted text-uppercase small fw-bold">Private Brand %</h6>
                    <h3 class="mb-0">28%</h3>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-6">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-white fw-bold">Income vs. Engagement (Total Spend)</div>
                <div class="card-body d-flex align-items-center justify-content-center">
                    <div class="text-center p-5 border border-dashed rounded bg-light">
                        <i class="bi bi-bar-chart-line display-4 text-secondary"></i>
                        <p class="mt-2 text-muted">[Bar Chart: Total Spend by Income Range]</p>
                    </div>
                </div>
                <div class="card-footer small text-muted">Question: How does income affect customer engagement?</div>
            </div>
        </div>

        <div class="col-lg-6">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-white fw-bold">Spending Trends (2018 - 2020)</div>
                <div class="card-body d-flex align-items-center justify-content-center">
                    <div class="text-center p-5 border border-dashed rounded bg-light">
                        <i class="bi bi-graph-up display-4 text-secondary"></i>
                        <p class="mt-2 text-muted">[Line Chart: Spend by Year/Month]</p>
                    </div>
                </div>
                <div class="card-footer small text-muted">Question: Are households spending more or less over time?</div>
            </div>
        </div>

        <div class="row g-4 mt-2">
            <div class="col-lg-6">
                <div class="card shadow-sm h-100">
                    <div class="card-header bg-white fw-bold">Feature Relationships: Brand Type</div>
                    <div class="card-body d-flex align-items-center justify-content-center">
                        <img src="charts/chart_feature_influence_to_brand.png" alt="Feature vs Brand Type" class="img-fluid rounded shadow" style="max-height:350px;" />
                    </div>
                    <div class="card-footer small text-muted">Relationship between features and brand type (private/public).</div>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="card shadow-sm h-100">
                    <div class="card-header bg-white fw-bold">Feature Relationships: Organic Flag</div>
                    <div class="card-body d-flex align-items-center justify-content-center">
                        <img src="charts/chart_feature_influence_organic.png" alt="Feature vs Organic Flag" class="img-fluid rounded shadow" style="max-height:350px;" />
                    </div>
                    <div class="card-footer small text-muted">Relationship between features and organic flag.</div>
                </div>
            </div>
        </div>

    </div>
</div>

