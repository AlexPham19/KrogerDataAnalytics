@page "/churn-prediction"
@using KrogerDataAnalytics.Service
@using System.IO
@using System.Globalization
@inject DataService DataService
@inject IWebHostEnvironment Env
@rendermode InteractiveServer

<div class="container-fluid p-4" style="background-color: #f4f7f6; min-height: 100vh;">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold" style="color: #1a237e;">Customer Churn Analysis</h2>
            <p class="text-muted">Predictive analytics powered by Random Forest Classification.</p>
        </div>
        <div class="text-end">
            <span class="badge bg-danger p-2 mb-1" style="font-size: 1rem;">
                High Risk: @(summaryMetrics.GetValueOrDefault("High Risk Households", "0")) Households
            </span><br />
            <small class="fw-bold text-primary">Model Accuracy: @(GetFormattedPercent("Accuracy"))</small>
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card shadow-sm border-0 border-top border-4 border-primary">
                <div class="card-body text-center">
                    <h6 class="text-muted small fw-bold text-uppercase">Precision</h6>
                    <h3 class="mb-0">@GetFormattedPercent("Precision")</h3>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card shadow-sm border-0 border-top border-4 border-success">
                <div class="card-body text-center">
                    <h6 class="text-muted small fw-bold text-uppercase">Recall</h6>
                    <h3 class="mb-0">@GetFormattedPercent("Recall")</h3>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card shadow-sm border-0 border-top border-4 border-info">
                <div class="card-body text-center">
                    <h6 class="text-muted small fw-bold text-uppercase">F1 Score</h6>
                    <h3 class="mb-0">@GetFormattedPercent("F1 Score")</h3>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card shadow-sm border-0 border-top border-4 border-warning">
                <div class="card-body text-center">
                    <h6 class="text-muted small fw-bold text-uppercase">ROC AUC</h6>
                    <h3 class="mb-0">@summaryMetrics.GetValueOrDefault("ROC AUC", "0.000")</h3>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-5">
            <div class="card shadow border-0 h-100">
                <div class="card-header bg-white py-3">
                    <h5 class="mb-0 fw-bold">Probability Distribution</h5>
                </div>
                <div class="card-body text-center">
                    @* Assuming graphs are in wwwroot/charts/ *@
                    <img src="charts/churn_probability_distribution.png" alt="Churn Probability Distribution" class="img-fluid rounded mb-3" style="max-height: 380px;" />
                    <div class="alert alert-secondary text-start small mb-0">
                        <strong>Insight:</strong> The model shows strong separation.
                        Targeting households with a probability > 0.7 captures most actual churners.
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-7">
            <div class="card shadow border-0 h-100">
                <div class="card-header bg-dark text-white py-3">
                    <h5 class="mb-0 fw-bold">Key Drivers of Churn</h5>
                </div>
                <div class="card-body">
                    <img src="charts/churn_feature_importance.png" alt="Feature Importance Graph" class="img-fluid rounded mb-3" />

                    <ul class="list-group list-group-flush mt-2">
                        @foreach (var feature in featureImportances.Take(5))
                        {
                            <li class="list-group-item d-flex justify-content-between align-items-center border-0 px-0">
                                <span class="small text-uppercase fw-bold text-muted">@feature.Name.Replace("_", " ")</span>
                                <div class="d-flex align-items-center w-50">
                                    <div class="progress flex-grow-1 me-2" style="height: 8px;">
                                        <div class="progress-bar bg-primary" style="width: @feature.Percent%;"></div>
                                    </div>
                                    <span class="small fw-bold">@feature.Percent.ToString("F1")%</span>
                                </div>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </div>
    </div>

    <div class="row mt-4">
        <div class="col-12">
            <div class="card shadow border-0">
                <div class="card-header bg-white py-3">
                    <h5 class="mb-0 fw-bold">Top 20 At-Risk Households</h5>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Household ID</th>
                                    <th>Actual Churn</th>
                                    <th>Probability</th>
                                    <th>Risk Level</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var hh in topAtRisk)
                                {
                                    <tr>
                                        <td class="fw-bold">#@hh.HshdNum.ToString().PadLeft(4, '0')</td>
                                        <td>
                                            <span class="badge @(hh.ChurnActual == 1 ? "bg-warning text-dark" : "bg-light text-muted")">
                                                @(hh.ChurnActual == 1 ? "Churned" : "Active")
                                            </span>
                                        </td>
                                        <td style="width: 250px;">
                                            <div class="d-flex align-items-center">
                                                <div class="progress flex-grow-1 me-2" style="height: 10px;">
                                                    <div class="progress-bar bg-danger" style="width: @(hh.ChurnProbability * 100)%;"></div>
                                                </div>
                                                <span class="small fw-bold">@hh.ChurnProbability.ToString("P1")</span>
                                            </div>
                                        </td>
                                        <td><span class="badge bg-danger">@hh.RiskLevel</span></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    // Data Structures
    public class AtRiskHH
    {
        public int HshdNum { get; set; }
        public int ChurnActual { get; set; }
        public double ChurnProbability { get; set; }
        public string RiskLevel { get; set; } = "";
    }

    public class FeatureImportance
    {
        public string Name { get; set; } = "";
        public double Percent { get; set; }
    }

    private List<AtRiskHH> topAtRisk = new();
    private List<FeatureImportance> featureImportances = new();
    private Dictionary<string, string> summaryMetrics = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadAllData();
    }

    private async Task LoadAllData()
    {
        try
        {
            string reportDir = Path.Combine(Env.WebRootPath, "reports");

            // 1. Load Summary Metrics
            var summaryLines = await File.ReadAllLinesAsync(Path.Combine(reportDir, "churn_summary_report.csv"));
            summaryMetrics = summaryLines.Skip(1)
                .Select(l => l.Split(','))
                .ToDictionary(cols => cols[0], cols => cols[1]);

            // 2. Load Feature Importance
            var featureLines = await File.ReadAllLinesAsync(Path.Combine(reportDir, "churn_feature_importance_report.csv"));
            featureImportances = featureLines.Skip(1)
                .Select(l => l.Split(','))
                .Select(cols => new FeatureImportance
                    {
                        Name = cols[0],
                        Percent = double.Parse(cols[2], CultureInfo.InvariantCulture)
                    }).OrderByDescending(f => f.Percent).ToList();

            // 3. Load Top 20 Households
            var riskLines = await File.ReadAllLinesAsync(Path.Combine(reportDir, "churn_top_20_at_risk_households.csv"));
            topAtRisk = riskLines.Skip(1)
                .Select(l => l.Split(','))
                .Select(cols => new AtRiskHH
                    {
                        HshdNum = int.Parse(cols[0]),
                        ChurnActual = int.Parse(cols[1]),
                        ChurnProbability = double.Parse(cols[2], CultureInfo.InvariantCulture),
                        RiskLevel = cols[4].Trim()
                    }).ToList();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading analytics: {ex.Message}");
        }
        finally
        {
            await InvokeAsync(StateHasChanged);
        }
    }

    private string GetFormattedPercent(string metricName)
    {
        if (summaryMetrics.TryGetValue(metricName, out var val) && double.TryParse(val, out var d))
        {
            return d <= 1 ? d.ToString("P1") : (d / 100).ToString("P1");
        }
        return "0.0%";
    }
}