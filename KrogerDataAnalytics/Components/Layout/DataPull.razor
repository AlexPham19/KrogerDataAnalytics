@page "/"
@using KrogerDataAnalytics.Components.Models
@using KrogerDataAnalytics.Service
@inject DataService DataService
@rendermode InteractiveServer

<div class="container-fluid p-4">
    <div class="text-center mb-4">
        <h1 class="fw-bold" style="color: #6a1b9a;">EXAMPLE DATA PULL FOR HH # @_searchQuery</h1>
        <div class="d-flex justify-content-center gap-2 align-items-center bg-light p-2 rounded shadow-sm mx-auto" style="max-width: 400px;">
            <span class="text-muted fw-bold">Sort by:</span>

            <select class="form-select form-select-sm w-auto border-primary"
                    value="@_selectedSort"
                    @onchange="HandleSortChange">
                <option value="Hshd_num">Hshd_num</option>
                <option value="Basket_num">Basket_num</option>
                <option value="Date">Date</option>
                <option value="Product_num">Product_num</option>
                <option value="Department">Department</option>
                <option value="Commodity">Commodity</option>
            </select>
        </div>
        <div class="d-flex justify-content-center gap-3 align-items-center bg-light p-3 rounded shadow-sm mx-auto mb-3" style="max-width: 600px;">
            <div class="input-group input-group-sm">
                <span class="input-group-text bg-primary text-white"><i class="bi bi-search"></i> HH #</span>
                <input type="text" class="form-control border-primary"
                       placeholder="Search Household..."
                       value="@_searchQuery"
                       @onchange="HandleSearchChange" />
            </div>            
        </div>
        <hr style="border-top: 3px solid #f06292; opacity: 1; width: 90%; margin: 15px auto;" />
    </div>

    @if (joinedResults == null)
    {
        <div class="text-center mt-5">
            <div class="spinner-border text-primary" role="status"></div>
            <p>Loading records from Azure...</p>
        </div>
    }
    else
    {
        <div class="table-responsive shadow-sm border rounded">
            <table class="table table-sm table-bordered mb-0 custom-data-table">
                <thead>
                    <tr>
                        <th>Hshd_num</th>
                        <th>Basket_num</th>
                        <th>Date</th>
                        <th>Product_num</th>
                        <th>Department</th>
                        <th>Commodity</th>
                        <th>Spend</th>
                        <th>Units</th>
                        <th>Store_region</th>
                        <th>Week_num</th>
                        <th>Year</th>
                        <th>Loyalty_flag</th>
                        <th>Age_range</th>
                        <th>Marital_status</th>
                        <th>Income_range</th>
                        <th>Homeowner_desc</th>
                        <th>Hshd_composition</th>
                        <th>Hshd_size</th>
                        <th>Children</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in joinedResults)
                    {
                        <tr>
                            <td class="col-hh-id">@row.Hshd_num.ToString().PadLeft(4, '0')</td>
                            <td class="col-trans">@row.Basket_num</td>
                            <td class="col-trans">@row.Date.ToString("MM/dd/yyyy")</td>
                            <td class="col-trans">@row.Product_num</td>
                            <td class="col-prod">@row.Department</td>
                            <td class="col-prod">@row.Commodity</td>
                            <td class="col-trans fw-bold">@row.Spend.ToString("F2")</td>
                            <td class="col-trans">@row.Units</td>
                            <td class="col-trans">@row.Store_region</td>
                            <td class="col-trans">@row.Week_num</td>
                            <td class="col-trans">@row.Year</td>
                            <td class="col-hh-demo">@row.Loyalty_flag</td>
                            <td class="col-hh-demo">@row.Age_range</td>
                            <td class="col-hh-demo">@row.Marital_status</td>
                            <td class="col-hh-demo">@row.Income_range</td>
                            <td class="col-hh-demo">@row.Homeowner_desc</td>
                            <td class="col-hh-demo">@row.Hshd_composition</td>
                            <td class="col-hh-demo">@row.Hshd_size</td>
                            <td class="col-hh-demo">@row.Children</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

<style>
    .custom-data-table thead th {
        background-color: #6a1b9a;
        color: white;
        font-size: 0.7rem;
        text-align: center;
        border: 1px solid #ffffff44;
    }

    .col-hh-id {
        background-color: #4a148c !important;
        color: #ffffff !important;
        font-weight: 800;
        text-shadow: 1px 1px 2px rgba(0,0,0,0.5);
    }

    .col-trans {
        background-color: #e0f7fa;
        color: #006064;
    }

    .col-prod {
        background-color: #fff9c4;
        color: #827717;
    }

    .col-hh-demo {
        background-color: #fce4ec;
        color: #880e4f;
    }

    .custom-data-table td {
        font-size: 0.72rem;
        text-align: center;
        border: 1px solid #dee2e6;
    }
</style>
@code {
    private List<JoinedTransaction>? _allResults; // The "Master" list
    private List<JoinedTransaction>? joinedResults; // The "Display" list

    private string _selectedSort = "Hshd_num";
    private string _searchQuery = "10";

    private string SearchQuery
    {
        get => _searchQuery;
        set
        {
            _searchQuery = value;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _allResults = await DataService.GetDataPullAsync(10);

            await ApplyFilters();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error: {ex.Message}");
            _allResults = new List<JoinedTransaction>();
            joinedResults = new List<JoinedTransaction>();
        }
    }
    private async Task HandleSearchChange(ChangeEventArgs e)
    {
        _searchQuery = e.Value?.ToString() ?? _searchQuery;
        await ApplyFilters();
    }

    private async Task HandleSortChange(ChangeEventArgs e)
    {
        _selectedSort = e.Value?.ToString() ?? "Hshd_num";
        await ApplyFilters();
    }

    private async Task ApplyFilters()
    {
        _allResults = await DataService.GetDataPullAsync(int.Parse(SearchQuery));

        if (_allResults == null) return;

        // 1. Start with the full list
        var filtered = _allResults.AsEnumerable();        

        // 3. Apply Sorting
        filtered = _selectedSort switch
        {
            "Basket_num" => filtered.OrderBy(x => x.Basket_num),
            "Date" => filtered.OrderBy(x => x.Date),
            "Product_num" => filtered.OrderBy(x => x.Product_num),
            "Department" => filtered.OrderBy(x => x.Department),
            "Commodity" => filtered.OrderBy(x => x.Commodity),
            _ => filtered.OrderBy(x => x.Hshd_num)
        };

        // 4. Update the Display list
        joinedResults = filtered.ToList();
        StateHasChanged();
    }
}